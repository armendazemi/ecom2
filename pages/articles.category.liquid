{% include 'header' %}
{% include 'page_breadcrumbs' %}
{% assign articlesToShow = 9 %}

<section
  class="padding-top-600 padding-top-lg-1200 padding-bottom-400 padding-bottom-lg-600 overflow-hidden">
  <div class="container">
    <div class="row justify-content-center row-gap-300 row-gap-lg-400">
      <div class="col-lg-6">
        <div class="d-flex flex-column row-gap-300 text-center">
          {{ 'news-archive-eyebrow' | global_editable: class: 'eyebrow display-subheading' }}
          {{ 'news-archive-heading' | global_editable: class: 'display-xxl-heading p-color-secondary' }}
        </div>
      </div>

      <div class="d-flex flex-column row-gap-lg-600 row-gap-400">
        <div class="col-12">
          <swiper-slider slides="auto" spaceBetween="12">
            <div class="swiper swiper-container d-flex justify-content-center w-fit-content">
              <div class="swiper-wrapper">

                <div class="swiper-slide w-fit-content">
                  <a href="/newsarchive"
                     class="category-button {% if request.path == "/newsarchive" %}active{% endif %}">
                    {{ "View all" | t }}
                  </a>
                </div>
                {% for cat in site.article_categories.all %}
                  <div class="swiper-slide w-fit-content">
                    <a href="{{ cat.url }}"
                       class="category-button {% if cat.id == category.id %}active{% endif %}">
                      {{ cat.name }}
                    </a>
                  </div>
                {% endfor %}
              </div>
            </div>
          </swiper-slider>
        </div>
        <div class="col-12">
          <div class="row row-gap-lg-600 row-gap-400">
            {% for article in category.articles[articlesToShow] %}
              <div class="col-lg-6 col-xl-4">
                {% assign blogImage = article.preview %}
                {% assign blogLink = article.url %}
                {% assign blogEyebrow = article.categories[0].name %}
                {% assign blogHeading = article.title %}
                {% assign blogText = article.preview_text %}
                {% include 'blog_card' %}
              </div>
            {% endfor %}


            <div class="col-md-12">
              {% assign totalArticles = articles.all.count %}
              {% assign totalPages = totalArticles | divided_by: articlesToShow %}
              {% assign rest = totalArticles | modulo: articlesToShow %}
              {% if rest > 0 %}
                {% assign totalPages = totalPages | plus: 1 %}
              {% endif %}
              <div
                class="pagination pagination--articles d-flex justify-content-end align-items-center">
                <span
                  class="margin-right-150">{{ "Sida" | t }} {{ request.params["page"] | fallback: 1 }} / {{ totalPages }}</span>
                <div class="article-paginate article-paginate__newer">
                  {{ 'Nyare' | paginate_previous_link }}
                </div>

                <div class="article-paginate article-paginate__older">
                  {{ 'Äldre' | paginate_next_link }}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% include 'footer' %}